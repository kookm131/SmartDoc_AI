# GEMINI_API_KEY: Gemini AI API 호출에 필요한 키입니다.
# AI Studio는 실행 시 사용자 시크릿에서 이 값을 자동 주입합니다.
# 사용자는 AI Studio UI의 Secrets 패널에서 값을 설정합니다.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: 이 앱이 호스팅되는 URL입니다.
# AI Studio는 실행 시 Cloud Run 서비스 URL을 자동 주입합니다.
# 자기 참조 링크, OAuth 콜백, API 엔드포인트 구성에 사용됩니다.
APP_URL="MY_APP_URL"

# 로컬 백엔드 API 타겟(Vite dev proxy)
VITE_GATEWAY_API_TARGET="http://localhost:8080"
VITE_DOCUMENT_API_TARGET="http://localhost:8081"
VITE_ANALYSIS_API_TARGET="http://localhost:8082"
VITE_NOTIFICATION_API_TARGET="http://localhost:8083"

# 로컬 백엔드 간 내부 호출 타겟
SMARTDOC_DOCUMENT_BASE_URL="http://localhost:8081"
SMARTDOC_ANALYSIS_BASE_URL="http://localhost:8082"
SMARTDOC_NOTIFICATION_BASE_URL="http://localhost:8083"
SMARTDOC_LOCAL_UPLOAD_DIR=".smartdoc/uploads"

# 로컬 개발용 Gateway 인증 설정
# 실제 운영/AWS 연동 시 SMARTDOC_AUTH_JWT_SECRET은 안전한 시크릿으로 교체합니다.
SMARTDOC_AUTH_JWT_SECRET="smartdoc-local-dev-secret-change-me"
SMARTDOC_AUTH_ACCESS_TOKEN_TTL_SECONDS="86400"
SMARTDOC_AUTH_DEV_EMAIL="test@smartdoc.local"
SMARTDOC_AUTH_DEV_PASSWORD="password"
SMARTDOC_AUTH_DEV_DISPLAY_NAME="SmartDoc Tester"

# VM MariaDB 연결 설정
# SPRING_PROFILES_ACTIVE=mariadb 로 실행할 때 사용합니다.
SPRING_PROFILES_ACTIVE="local"
SMARTDOC_DB_HOST="127.0.0.1"
SMARTDOC_DB_PORT="3306"
SMARTDOC_DB_USERNAME="smartdoc"
SMARTDOC_DB_PASSWORD="CHANGE_ME"

# 서비스별 DB URL을 직접 지정해야 할 때만 사용합니다.
# SMARTDOC_GATEWAY_DATASOURCE_URL="jdbc:mariadb://127.0.0.1:3306/smartdoc_gateway?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Seoul"
# SMARTDOC_DOCUMENT_DATASOURCE_URL="jdbc:mariadb://127.0.0.1:3306/smartdoc_document?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Seoul"
# SMARTDOC_ANALYSIS_DATASOURCE_URL="jdbc:mariadb://127.0.0.1:3306/smartdoc_analysis?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Seoul"
# SMARTDOC_NOTIFICATION_DATASOURCE_URL="jdbc:mariadb://127.0.0.1:3306/smartdoc_notification?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Seoul"
